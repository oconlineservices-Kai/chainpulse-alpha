# ============================================================
# ChainPulse Alpha — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# `cp .env.example .env`

# ── Database ──────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@ep-example-123456.us-east-2.aws.neon.tech/chainpulse?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000          # Production: https://chainpulse.dev
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Razorpay Payments ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Telegram Bot ──────────────────────────────────────────────
# Decommissioned — the bot is no longer part of the system
# TELEGRAM_BOT_TOKEN=1234567890:AAHxxx...your_bot_token
# TELEGRAM_BOT_USERNAME=ChainPulseAlertBot   # Without @

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com               # Email that gets admin access

# ── Optional (defaults used if omitted) ───────────────────────
# NODE_ENV=production
