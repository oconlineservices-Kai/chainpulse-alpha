# ============================================================
# ChainPulse Alpha — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# `cp .env.example .env`

# ── Database ──────────────────────────────────────────────────
# 🚨 IMPORTANT: Use the **pooled** connection string for production!
# Neon direct connections close idle connections after ~5 min, causing
# "Server has closed the connection" errors on Prisma queries.
#
# Pooled (add -pooler suffix to hostname):
#   postgresql://user:pass@ep-example-123456-pooler.us-east-2.aws.neon.tech/chainpulse?sslmode=require&pgbouncer=true
#
# Direct (avoids PgBouncer — use only for dev/migrations):
#   postgresql://user:pass@ep-example-123456.us-east-2.aws.neon.tech/chainpulse?sslmode=require
NEON_DATABASE_URL=postgresql://user:pass@ep-example-123456.us-east-2.aws.neon.tech/chainpulse?sslmode=require

# ── Prisma Connection Pool ─────────────────────────────────────
# Controls the number of connections in the Prisma pool (default: 4).
# Increase if you see "Server has closed the connection" under concurrent load.
# With Neon pooled URLs (-pooler), a higher limit (like 10-20) is safe.
# PRISMA_CONNECTION_LIMIT=10

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000          # Production: https://chainpulse.dev
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Razorpay Payments ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Telegram Bot ──────────────────────────────────────────────
# Decommissioned — the bot is no longer part of the system
# TELEGRAM_BOT_TOKEN=1234567890:AAHxxx...your_bot_token
# TELEGRAM_BOT_USERNAME=ChainPulseAlertBot   # Without @

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com               # Email that gets admin access

# ── Optional (defaults used if omitted) ───────────────────────
# NODE_ENV=production
